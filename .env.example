# RésiHub — variables d'environnement (copiez ce fichier en `.env` et remplissez).
# NE COMMITEZ JAMAIS le vrai .env : il est ignoré par git (.gitignore).

# Serveur
PORT=8080
PUBLIC_URL=http://localhost:8080

# Stripe — commencez avec les clés de TEST (sk_test_...).
# La clé secrète reste côté serveur uniquement, jamais dans le front.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ANNUAL=price_xxx_annuel
STRIPE_PRICE_MONTHLY=price_xxx_mensuel
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base de données (à venir : Postgres / Supabase)
DATABASE_URL=
